{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "日报助手",
  "version": "0.1.0",
  "identifier": "com.codex.daily-report-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "日报助手",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
